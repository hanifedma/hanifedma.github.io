# LaTeX portfolio: track only the source and the final PDF;
# ignore all the latexmk build artifacts (.aux, .log, .fls, .fdb_latexmk,
# .nav, .out, .snm, .toc) and the duplicate portfolio.pdf.
portfolio-pdf/*
!portfolio-pdf/portfolio.tex
!portfolio-pdf/Portfolio_Hanif_Edma_Fauz.pdf
resume/resume.aux
resume/resume.fdb_latexmk
resume/resume.fls
resume/resume.log
resume/resume.out
resume/resume.pdf
resume/resume.synctex.gz
